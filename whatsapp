/**
 * WhatsApp API Service
 * API:add your own
 */

const WA_BASE = 'add ypur own';
const WA_USERNAME = '';
const WA_TOKEN = '';

/**
 * Send a WhatsApp message to a single number
 * @param {string} number - Mobile number with country code e.g. "919876543210"
 * @param {string} message - Message text
 * @returns {Promise<{success: boolean, error?: string}>}
 */
export async function sendWhatsAppMessage(number, message, retries = 2) {
  const encodedMsg = encodeURIComponent(message);
  const cleanNumber = number.replace(/[^0-9]/g, '');
  const url = `${WA_BASE}?username=${WA_USERNAME}&number=${cleanNumber}&message=${encodedMsg}&token=${WA_TOKEN}`;

  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const response = await fetch(url, {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' },
      });

      const text = await response.text();
      let data;
      try { data = JSON.parse(text); } catch { data = { raw: text }; }

      if (response.ok) {
        return { success: true, data };
      } else {
        if (attempt === retries) {
          return { success: false, error: data?.message || `HTTP ${response.status}` };
        }
        await delay(1000 * (attempt + 1));
      }
    } catch (e) {
      if (attempt === retries) {
        return { success: false, error: e.message || 'Network error' };
      }
      await delay(1000 * (attempt + 1));
    }
  }
  return { success: false, error: 'Max retries exceeded' };
}

/**
 * Send to multiple numbers (group broadcast)
 * @param {string[]} numbers - Array of mobile numbers
 * @param {string} message - Message text
 * @param {function} onProgress - Called with (index, total, number, success)
 */
export async function sendWhatsAppBroadcast(numbers, message, onProgress) {
  const results = [];
  for (let i = 0; i < numbers.length; i++) {
    const number = numbers[i];
    const result = await sendWhatsAppMessage(number, message);
    results.push({ number, ...result });
    if (onProgress) onProgress(i + 1, numbers.length, number, result.success);
    if (i < numbers.length - 1) await delay(800); // avoid rate limiting
  }
  return results;
}

function delay(ms) {
  return new Promise(r => setTimeout(r, ms));
}
